PORT=3001
# PostgreSQL Connection pool (pgbouncer) for Supabase
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-URL]:6543/postgres?pgbouncer=true"
# Direct PostgreSQL connection for Prisma Migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-URL]:5432/postgres"

# Upstash Redis URL for WebSockets Pub/Sub Scaling
REDIS_URL="rediss://default:[YOUR-UPSTASH-PASSWORD]@[YOUR-UPSTASH-URL]:6379"

# JWT Secret Key for authenticating WebSockets and API Routes
JWT_SECRET="generate-a-super-secret-key-here"
